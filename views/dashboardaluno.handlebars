
<h1 class="mb-2">Dashboard</h1>
{{#if motivationalMessage}}
    <p class="small text-secondary mt-1 fst-italic text-center border rounded-2 px-3 py-2 mb-2">"{{motivationalMessage}}"</p>
{{/if}}

<style>
    .dashboard-card-link {
        color: inherit;
        text-decoration: none;
    }

    .dashboard-card {
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 0.85rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        min-height: 170px;
        background-color: #ffffff;
    }

    .dashboard-card:hover,
    .dashboard-card:focus-within {
        transform: translateY(-4px);
        border-color: rgba(13, 110, 253, 0.6);
        box-shadow: 0 0.75rem 1.25rem rgba(0, 0, 0, 0.08);
        background-color: #f8fbff;
    }

    .dashboard-card-icon {
        font-size: 2rem;
        margin-bottom: 0.75rem;
    }

    @media (max-width: 767.98px) {
        .dashboard-card {
            min-height: auto;
        }
    }
</style>

<div class="row g-3 justify-content-center">
    <div class="col-6 col-md-3 d-flex">
        <a href="/presenca" class="dashboard-card-link w-100">
            <div class="card dashboard-card w-100 h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <i class="fa-solid fa-calendar-check dashboard-card-icon text-primary"></i>
                    <h5 class="card-title mb-2">Minhas Presenças</h5>
                    <p class="card-text text-body-secondary mb-0 d-none d-md-block">Controle as suas presenças e registros de participação de aula.</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-6 col-md-3 d-flex">
        <a href="/metasdeaula" class="dashboard-card-link w-100">
            <div class="card dashboard-card w-100 h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <i class="fa-solid fa-award dashboard-card-icon text-warning"></i>
                    <h5 class="card-title mb-2">Metas de aulas</h5>
                    <p class="card-text text-body-secondary mb-0 d-none d-md-block">Defina objetivos e acompanhe evolução das turmas.</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-12 col-md-6 d-flex">
        <a href="#" class="dashboard-card-link w-100" aria-disabled="true">
            <div class="card dashboard-card w-100 h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                    <i class="fa-solid fa-chart-pie dashboard-card-icon text-info"></i>
                    <h5 class="card-title mb-2">Relatórios</h5>
                    <p class="card-text text-body-secondary mb-0 d-none d-md-block">Exibir relatórios de desempenho, progresso e presenças.</p>
                </div>
            </div>
        </a>
    </div>
</div>

{{> birthdayswidget birthdayWidget}}
