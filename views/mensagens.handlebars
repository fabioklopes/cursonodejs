{{#if mensagem}}
<div class="alert alert-{{tipoMensagem}} alert-autodismiss" role="alert">
    {{#if (eq tipoMensagem 'danger')}}<i class="fa-solid fa-circle-xmark"></i>{{else}}<i class="fa-solid fa-circle-check"></i>{{/if}} {{mensagem}}
</div>
{{/if}}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <h1 class="mb-0">Mensagens</h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalNovaMensagemMassa">
        <i class="fa-solid fa-bullhorn"></i> Nova mensagem
    </button>
</div>

<div class="row g-3 mb-2">
    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-light d-flex align-items-center justify-content-between">
                <span><i class="fa-solid fa-circle-check text-success"></i> Mensagens ativas</span>
                <span class="small text-body-secondary">Total: {{mensagensAtivas.length}}</span>
            </div>
            <div class="card-body">
                {{#if mensagensAtivas.length}}
                <div class="mensagens-table-scroll border rounded-3">
                    <table class="table table-hover align-middle mb-0 mensagens-table-fixed">
                        <thead class="table-light position-sticky top-0">
                            <tr>
                                <th scope="col">Título</th>
                                <th scope="col" class="text-end">Expira em</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each mensagensAtivas}}
                            <tr
                                class="mensagem-row-clickable"
                                data-id="{{id}}"
                                data-title="{{title}}"
                                data-content="{{content}}"
                                data-class-code="{{class_code}}"
                                data-class-display="{{class_display}}"
                                data-created-at="{{createdAtLabel}}"
                                data-expires-at="{{expiresAtLabel}}"
                                data-expires-at-input="{{expiresAtInputValue}}"
                                data-status-label="{{statusLabel}}"
                                data-status-badge="{{statusBadge}}"
                                role="button"
                                tabindex="0"
                            >
                                <td>{{title}}</td>
                                <td class="text-end">{{expiresAtLabel}}</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                <p class="text-body-secondary mb-0">Nenhuma mensagem ativa.</p>
                {{/if}}
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-light d-flex align-items-center justify-content-between">
                <span><i class="fa-solid fa-clock text-secondary"></i> Mensagens expiradas</span>
                <span class="small text-body-secondary">Total: {{mensagensExpiradas.length}}</span>
            </div>
            <div class="card-body">
                {{#if mensagensExpiradas.length}}
                <div class="mensagens-table-scroll border rounded-3">
                    <table class="table table-hover align-middle mb-0 mensagens-table-fixed">
                        <thead class="table-light position-sticky top-0">
                            <tr>
                                <th scope="col">Título</th>
                                <th scope="col" class="text-end">Criada em</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each mensagensExpiradas}}
                            <tr
                                class="mensagem-row-clickable"
                                data-id="{{id}}"
                                data-title="{{title}}"
                                data-content="{{content}}"
                                data-class-code="{{class_code}}"
                                data-class-display="{{class_display}}"
                                data-created-at="{{createdAtLabel}}"
                                data-expires-at="{{expiresAtLabel}}"
                                data-expires-at-input="{{expiresAtInputValue}}"
                                data-status-label="{{statusLabel}}"
                                data-status-badge="{{statusBadge}}"
                                role="button"
                                tabindex="0"
                            >
                                <td>{{title}}</td>
                                <td class="text-end">{{createdAtLabel}}</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
                {{else}}
                <p class="text-body-secondary mb-0">Nenhuma mensagem expirada.</p>
                {{/if}}
            </div>
        </div>
    </div>
</div>

{{!-- <p class="small text-body-secondary mb-3">Total geral: {{totalMensagens}}</p> --}}

<div class="modal fade" id="modalNovaMensagemMassa" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="POST" action="/mensagens" id="formNovaMensagemMassa">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa-solid fa-bullhorn"></i>Aviso Geral</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cancelar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="mensagemTitle" class="form-label">Título</label>
                        <input type="text" id="mensagemTitle" name="title" class="form-control" maxlength="50" required>
                        <div class="form-text">Máximo de 50 caracteres.</div>
                    </div>

                    <div class="mb-3">
                        <label for="mensagemContent" class="form-label">Mensagem</label>
                        <textarea id="mensagemContent" name="content" class="form-control" rows="4" maxlength="255" required></textarea>
                        <div class="form-text">Máximo de 255 caracteres.</div>
                    </div>

                    <div class="mb-3">
                        <label for="mensagemExpiresAt" class="form-label">Data de expiração</label>
                        <input type="datetime-local" id="mensagemExpiresAt" name="expires_at" class="form-control" value="{{defaultExpireAt}}" required>
                    </div>

                    <div class="mb-1">
                        <label class="form-label">Selecione a turma para receber a mensagem</label>
                        <div class="mass-message-class-picker" id="mensagemClassesPicker">
                            {{#each turmas}}
                            <label class="mass-message-class-card">
                                <input type="checkbox" name="class_codes" value="{{class_code}}" class="form-check-input mass-message-class-checkbox">
                                <span class="mass-message-class-content">
                                    <span class="mass-message-class-name">{{class_name}}</span>
                                </span>
                            </label>
                            {{/each}}
                        </div>
                        <div class="form-text">Marque uma ou mais turmas para enviar o aviso.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="btnConfirmarNovaMensagemMassa">Confirmar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalDetalheMensagemMassa" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa-solid fa-bullhorn"></i> Editar Aviso Geral</h5>
            </div>
            <form id="reativarMensagemForm" method="POST" action="/mensagens/0/reativar">
            <div class="modal-body">
                <div class="mb-3">
                    <label for="reativarMensagemTitulo" class="form-label">Título</label>
                    <input type="text" id="reativarMensagemTitulo" name="reactivate_title" class="form-control" maxlength="50" required>
                    <div class="form-text">Máximo de 50 caracteres.</div>
                </div>

                <div class="mb-3">
                    <label for="reativarMensagemConteudo" class="form-label">Mensagem</label>
                    <textarea id="reativarMensagemConteudo" name="reactivate_content" class="form-control" rows="4" maxlength="255" required></textarea>
                </div>

                <div class="mb-3">
                    <label for="reativarMensagemExpiresAt" class="form-label">Nova data de expiração</label>
                    <input type="datetime-local" id="reativarMensagemExpiresAt" name="reactivate_expires_at" class="form-control" required>
                </div>

                <div class="mb-0">
                    <label class="form-label">Turma alvo</label>
                    <div class="mass-message-class-picker" id="reativarMensagemClassesPicker">
                        {{#each turmas}}
                        <label class="mass-message-class-card mass-message-class-card-single">
                            <input type="checkbox" name="reactivate_class_codes" value="{{class_code}}" class="form-check-input mass-message-reactivate-checkbox">
                            <span class="mass-message-class-content">
                                <span class="mass-message-class-name">{{class_name}}</span>
                            </span>
                        </label>
                        {{/each}}
                    </div>
                    <div class="form-text">Marque uma ou mais turmas para reativar e replicar este aviso.</div>
                </div>
            </div>
            <div class="modal-footer justify-content-between flex-column flex-md-row gap-2 align-items-stretch">
                <button type="submit" class="btn btn-outline-primary text-nowrap">Salvar</button>
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Fechar</button>
            </div>
            </form>
        </div>
    </div>
</div>

<style>
    .mensagens-table-scroll {
        max-height: 320px;
        overflow-y: auto;
        overflow-x: hidden;
    }

    .mensagens-table-fixed {
        width: 100%;
        table-layout: fixed;
        font-size: 0.9rem;
    }

    .mensagem-row-clickable {
        cursor: pointer;
    }

    .mass-message-class-picker {
        max-height: 240px;
        overflow-y: auto;
        border: 1px solid var(--bs-border-color);
        border-radius: 0.75rem;
        padding: 0.75rem;
        display: grid;
        gap: 0.6rem;
    }

    .mass-message-class-card {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        border: 1px solid var(--bs-border-color);
        border-radius: 0.75rem;
        padding: 0.75rem;
        background-color: var(--bs-body-bg);
        cursor: pointer;
    }

    .mass-message-class-card:hover {
        border-color: var(--bs-primary);
        background-color: rgba(13, 110, 253, 0.04);
    }

    .mass-message-class-content {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .mass-message-class-name {
        font-weight: 600;
    }

</style>

<script>
    (function() {
        function initMensagensPage() {
            const rows = Array.from(document.querySelectorAll('.mensagem-row-clickable'));
            const modalElement = document.getElementById('modalDetalheMensagemMassa');
            const formNovaMensagem = document.getElementById('formNovaMensagemMassa');
            const btnConfirmarNovaMensagem = document.getElementById('btnConfirmarNovaMensagemMassa');

            if (formNovaMensagem && btnConfirmarNovaMensagem) {
                formNovaMensagem.addEventListener('submit', function() {
                    if (btnConfirmarNovaMensagem.disabled) {
                        return;
                    }

                    btnConfirmarNovaMensagem.disabled = true;
                    btnConfirmarNovaMensagem.textContent = 'Enviando...';
                });
            }

            if (!modalElement || rows.length === 0) {
                return;
            }

            if (typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                return;
            }

            const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
            const reativarForm = document.getElementById('reativarMensagemForm');
            const reativarTitulo = document.getElementById('reativarMensagemTitulo');
            const reativarConteudo = document.getElementById('reativarMensagemConteudo');
            const reativarInput = document.getElementById('reativarMensagemExpiresAt');
            const reativarClassCheckboxes = Array.from(document.querySelectorAll('.mass-message-reactivate-checkbox'));

            function syncClassCardState(scopeSelector) {
                const checkboxes = Array.from(document.querySelectorAll(scopeSelector));
                checkboxes.forEach((checkbox) => {
                    const card = checkbox.closest('.mass-message-class-card');
                    if (!card) {
                        return;
                    }

                    card.classList.toggle('border-primary', checkbox.checked);
                    card.classList.toggle('bg-primary-subtle', checkbox.checked);
                });
            }

            Array.from(document.querySelectorAll('.mass-message-class-checkbox')).forEach((checkbox) => {
                checkbox.addEventListener('change', function() {
                    syncClassCardState('.mass-message-class-checkbox');
                });
            });

            reativarClassCheckboxes.forEach((checkbox) => {
                checkbox.addEventListener('change', function() {
                    syncClassCardState('.mass-message-reactivate-checkbox');
                });
            });

            function openByRow(row) {
                const id = row.getAttribute('data-id') || '0';
                const classCode = row.getAttribute('data-class-code') || '';

                if (reativarForm) {
                    reativarForm.action = `/mensagens/${id}/reativar`;
                }

                if (reativarTitulo) {
                    reativarTitulo.value = row.getAttribute('data-title') || '';
                }

                if (reativarConteudo) {
                    reativarConteudo.value = row.getAttribute('data-content') || '';
                }

                if (reativarInput) {
                    reativarInput.value = row.getAttribute('data-expires-at-input') || '';
                }

                reativarClassCheckboxes.forEach((checkbox) => {
                    checkbox.checked = checkbox.value === classCode;
                });
                syncClassCardState('.mass-message-reactivate-checkbox');

                modal.show(row);
            }

            rows.forEach((row) => {
                row.addEventListener('click', function() {
                    openByRow(row);
                });

                row.addEventListener('keydown', function(event) {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        openByRow(row);
                    }
                });
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initMensagensPage);
        } else {
            initMensagensPage();
        }
    })();
</script>
