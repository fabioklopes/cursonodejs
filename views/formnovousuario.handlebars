{{#if mensagem}}
<div class="alert alert-warning text-center alert-autodismiss" role="alert">{{mensagem}}</div>
{{/if}}

<form action="{{formAction}}" method="POST" enctype="multipart/form-data">

    {{#unless isEditMode}}
    <!-- Bloco de escolha: Para mim / Dependentes -->
    <div class="row mb-4 text-center g-2 justify-content-center" id="tipo-conta-cards">
        <div class="col-6 col-md-6 d-flex">
            <div class="card w-100 h-100 border-2 selectable-card" id="card-para-mim" role="button" tabindex="0"
                style="cursor:pointer;">
                <div class="card-body">
                    <i class="fa-solid fa-person fa-2xl text-primary"></i> <br><br>
                    <h5 class="card-title">Para mim</h5>
                    <p class="card-text">Vou gerenciar apenas uma conta</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-6 d-flex">
            <div class="card w-100 h-100 border-2 selectable-card" id="card-dependente" role="button" tabindex="0"
                style="cursor:pointer;">
                <div class="card-body">
                    <i class="fa-solid fa-hands-holding-child fa-2xl text-success"></i> <br><br>
                    <h5 class="card-title">Dependentes</h5>
                    <p class="card-text">Vou gerenciar mais de uma conta</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Bloco de verificação do e-mail do titular (só aparece ao clicar em Dependentes) -->
    <div id="verificar-titular-container" class="mb-4" style="display:none;">
        <div class="card border-success">
            <div class="card-body">
                <h6 class="card-title text-success">
                    <i class="fa-solid fa-circle-check"></i> Verificação da conta titular
                </h6>
                <p class="text-muted small">Informe o e-mail da conta responsável (titular). Ela precisa estar ativa no
                    sistema.</p>

                <div id="verificar-form-group">
                    <div class="input-group mb-2">
                        <input type="email" class="form-control" id="titular-email-input"
                            placeholder="E-mail do titular" autocomplete="off">
                        <button type="button" class="btn btn-success" id="btn-verificar-titular">
                            <i class="fa-solid fa-magnifying-glass"></i> Verificar
                        </button>
                    </div>
                    <div id="titular-feedback" class="form-text"></div>
                </div>

                <!-- Exibido após verificação com sucesso -->
                <div id="titular-verificado-info" style="display:none;" class="alert alert-success py-2 mb-0">
                    <i class="fa-solid fa-circle-check"></i>
                    Titular verificado: <strong id="titular-nome"></strong>
                    <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-2" id="btn-trocar-titular">
                        trocar
                    </button>
                </div>
            </div>
        </div>
    </div>
    {{/unless}}

    <!-- Campo hidden para responsible_id (dependente) -->
    <input type="hidden" name="responsible_id" id="responsible-id-input" value="">

    <!-- Formulário principal (oculto até o usuário escolher o tipo de conta no modo de cadastro) -->
    <div id="form-fields-container" style="{{#if isEditMode}}display:block{{else}}display:none{{/if}}">
        <div class="form-floating mb-3">
            <input type="text" class="form-control" name="first_name" value="{{usuario.first_name}}" placeholder=""
                {{#if isEditMode}}readonly{{/if}}>
            <label for="firstName">Primeiro nome</label>
        </div>

        <div class="form-floating mb-3">
            <input type="text" class="form-control" name="last_name" value="{{usuario.last_name}}" placeholder="" {{#if
                isEditMode}}readonly{{/if}}>
            <label for="lastName">Restante do nome</label>
        </div>

        <div class="form-floating mb-3">
            <input type="email" class="form-control" name="email" id="email-input" value="{{usuario.email}}"
                placeholder="" required>
            <label for="email">E-mail</label>
            <div class="form-text text-muted" id="email-hint-dependente" style="display:none;">
                Para dependentes, o e-mail é opcional. Se não preenchido, será gerado automaticamente.
            </div>
        </div>

        <div class="form-floating mb-3">
            <input type="password" class="form-control" name="password1" placeholder="" {{#unless
                isEditMode}}required{{/unless}}>
            <label for="password1">{{#if isEditMode}}Nova senha (opcional){{else}}Senha{{/if}}</label>
        </div>

        <div class="form-floating mb-3">
            <input type="password" class="form-control" name="password2" placeholder="" {{#unless
                isEditMode}}required{{/unless}}>
            <label for="password">{{#if isEditMode}}Repita a nova senha{{else}}Repita a sua senha{{/if}}</label>
        </div>

        <div class="form-floating mb-3">
            <input type="phone" class="form-control" name="phone" value="{{usuario.phone}}" placeholder="" required>
            <label for="phone">WhatsApp (apenas números)</label>
        </div>

        <div class="form-floating mb-3">
            <input type="date" class="form-control" name="birth_date" value="{{usuario.birth_date}}" placeholder="" {{#if isEditMode}}readonly{{else}}required{{/if}}>
            <label for="birth_date">Aniversário</label>
        </div>

        <div class="form-floating mb-3">
            <select class="form-select" name="actual_belt" aria-label="" required>
                <option value="">-- Selecione --</option>
                {{#each beltOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
            </select>
            <label for="actual_belt">Faixa Atual</label>
        </div>

        <div class="form-floating mb-3">
            <input type="number" min="0" max="6" class="form-control" name="actual_degree"
                value="{{usuario.actual_degree}}" placeholder="" required>
            <label for="actual_degree">Grau (se não tiver grau, coloque zero)</label>
        </div>

        <div class="form-floating mb-3">
            <input type="text" class="form-control" name="wagi_size" value="{{usuario.wagi_size}}" placeholder=""
                required>
            <label for="wagi_size">Tamanho - Parte de cima do kimono (Wagi)</label>
        </div>

        <div class="form-floating mb-3">
            <input type="text" class="form-control" name="zubon_size" value="{{usuario.zubon_size}}" placeholder=""
                required>
            <label for="zubon_size">Tamanho - Parte de baixo do kimono (Zubon)</label>
        </div>

        <div class="form-floating mb-3">
            <input type="text" class="form-control" name="obi_size" value="{{usuario.obi_size}}" placeholder=""
                required>
            <label for="obi_size">Tamanho - Faixa (Obi)</label>
        </div>

        {{#if isEditMode}}
        <div class="form-floating mb-3">
            <input type="text" class="form-control" value="{{usuario.photo}}" readonly>
            <label for="photo">Foto atual no banco</label>
        </div>
        {{/if}}

        <div class="mb-3">
            <label for="photo-input" class="form-label text-danger">
                Envie uma foto sua, de rosto, para o seu avatar de perfil
            </label>
            <label for="photo-input" class="form-label text-secondary">
                A foto é importantes para o professor aprovar as suas presenças nas aulas. Se você não enviar uma foto,
                o seu perfil ficará com um avatar genérico e o professor não conseguirá identificar você para aprovar
                suas presenças.
            </label>
            <input type="file" class="form-control" id="photo-input" name="photo" accept="image/*" placeholder="" required>
            <small class="form-text text-muted small">Máximo 1MB. Enquadre seu rosto em uma área de 200x200
                pixels.</small>
        </div>

        {{#if isEditMode}}
        <div class="mb-3">
            <label class="form-label">Avatar atual</label>
            <div style="width: 120px; height: 120px; border: 2px solid #ddd; border-radius: 8px; overflow: hidden;">
                <img src="{{usuario.photo}}" alt="Avatar atual" style="width: 100%; height: 100%; object-fit: cover;">
            </div>
        </div>
        {{/if}}

        <!-- Visualização e corte da imagem -->
        <div id="crop-container" class="mb-3" style="display: none;">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title">Ajuste sua foto</h6>
                    <div style="max-height: 400px; overflow: hidden; margin-bottom: 15px;">
                        <img id="cropper-image" style="max-width: 100%;" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-secondary" id="rotate-left"><i
                                class="fa-solid fa-rotate-left"></i> Girar</button>
                        <button type="button" class="btn btn-sm btn-success" id="crop-confirm"><i
                                class="fa-solid fa-check"></i> Usar esta imagem</button>
                        <button type="button" class="btn btn-sm btn-danger" id="crop-cancel"><i
                                class="fa-solid fa-times"></i> Cancelar</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Visualização da imagem recortada -->
        <div id="preview-container" class="mb-3" style="display: none;">
            <label class="form-label">Prévia da sua foto:</label>
            <div style="width: 200px; height: 200px; border: 2px solid #ddd; border-radius: 8px; overflow: hidden;">
                <img id="preview-image" style="width: 100%; height: 100%; object-fit: cover;" />
            </div>
            <input type="hidden" id="photo-data" />
        </div>

        <button type="submit" class="btn btn-primary">{{submitLabel}}</button>

        <!-- Fecha form-fields-container (novo) ou div vazio de editMode -->
    </div>
</form>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const photoInput = document.getElementById('photo-input');
        const cropContainer = document.getElementById('crop-container');
        const cropperImage = document.getElementById('cropper-image');
        const previewContainer = document.getElementById('preview-container');
        const previewImage = document.getElementById('preview-image');
        const photoData = document.getElementById('photo-data');
        const rotateLeftBtn = document.getElementById('rotate-left');
        const cropConfirmBtn = document.getElementById('crop-confirm');
        const cropCancelBtn = document.getElementById('crop-cancel');

        let cropper = null;

        photoInput.addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function (event) {
                cropperImage.src = event.target.result;
                cropContainer.style.display = 'block';
                previewContainer.style.display = 'none';

                if (cropper) {
                    cropper.destroy();
                }

                cropper = new Cropper(cropperImage, {
                    aspectRatio: 1,
                    viewMode: 1,
                    autoCropArea: 1,
                    responsive: true,
                    guides: true,
                    highlight: true,
                    cropBoxMovable: true,
                    cropBoxResizable: true,
                    toggleDragModeOnDblclick: true,
                });
            };
            reader.readAsDataURL(file);
        });

        rotateLeftBtn.addEventListener('click', function () {
            if (cropper) {
                cropper.rotate(-90);
            }
        });

        cropConfirmBtn.addEventListener('click', function () {
            if (!cropper) return;

            const canvas = cropper.getCroppedCanvas({
                maxWidth: 200,
                maxHeight: 200,
                fillColor: '#fff',
                imageSmoothingEnabled: true,
                imageSmoothingQuality: 'high',
            });

            // Mostrar prévia
            previewImage.src = canvas.toDataURL();
            previewImage.style.borderRadius = '8px';

            // Converter canvas para blob e criar arquivo
            canvas.toBlob(function (blob) {
                const file = new File([blob], 'photo.jpg', { type: 'image/jpeg' });
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(file);
                photoInput.files = dataTransfer.files;
                photoData.value = canvas.toDataURL();

                cropContainer.style.display = 'none';
                previewContainer.style.display = 'block';
            }, 'image/jpeg', 0.95);
        });

        cropCancelBtn.addEventListener('click', function () {
            photoInput.value = '';
            cropContainer.style.display = 'none';
            previewContainer.style.display = 'none';
            if (cropper) {
                cropper.destroy();
                cropper = null;
            }
        });
    });
</script>

{{#unless isEditMode}}
<script>
    (function () {
        const cardParaMim = document.getElementById('card-para-mim');
        const cardDependente = document.getElementById('card-dependente');
        const verificarContainer = document.getElementById('verificar-titular-container');
        const formFieldsContainer = document.getElementById('form-fields-container');
        const responsibleIdInput = document.getElementById('responsible-id-input');
        const emailInput = document.getElementById('email-input');
        const emailHintDep = document.getElementById('email-hint-dependente');
        const titularEmailInput = document.getElementById('titular-email-input');
        const btnVerificar = document.getElementById('btn-verificar-titular');
        const titularFeedback = document.getElementById('titular-feedback');
        const titularVerificadoInfo = document.getElementById('titular-verificado-info');
        const titularNome = document.getElementById('titular-nome');
        const btnTrocarTitular = document.getElementById('btn-trocar-titular');

        function selecionarCard(cardSelecionado, cardOutro) {
            cardSelecionado.classList.add('border-primary', 'bg-primary-subtle');
            cardOutro.classList.remove('border-primary', 'bg-primary-subtle', 'border-success', 'bg-success-subtle');
        }

        function mostrarFormulario() {
            formFieldsContainer.style.display = 'block';
        }

        // Clique em "Para mim"
        cardParaMim.addEventListener('click', function () {
            selecionarCard(cardParaMim, cardDependente);
            verificarContainer.style.display = 'none';
            responsibleIdInput.value = '';
            emailInput.required = true;
            emailInput.readOnly = false;
            emailHintDep.style.display = 'none';
            mostrarFormulario();
        });

        cardParaMim.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); cardParaMim.click(); }
        });

        // Clique em "Dependentes"
        cardDependente.addEventListener('click', function () {
            selecionarCard(cardDependente, cardParaMim);
            cardDependente.classList.remove('border-primary', 'bg-primary-subtle');
            cardDependente.classList.add('border-success', 'bg-success-subtle');
            verificarContainer.style.display = 'block';
            formFieldsContainer.style.display = 'none';
            responsibleIdInput.value = '';
            // Redefinir estado do painel de verificação
            titularVerificadoInfo.style.display = 'none';
            document.getElementById('verificar-form-group').style.display = 'block';
            titularFeedback.textContent = '';
            titularEmailInput.value = '';
        });

        cardDependente.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); cardDependente.click(); }
        });

        // Botão Verificar titular
        btnVerificar.addEventListener('click', async function () {
            const email = titularEmailInput.value.trim();
            if (!email) {
                titularFeedback.textContent = 'Informe o e-mail do titular.';
                titularFeedback.className = 'form-text text-danger';
                return;
            }

            btnVerificar.disabled = true;
            titularFeedback.textContent = 'Verificando...';
            titularFeedback.className = 'form-text text-muted';

            try {
                const resp = await fetch('/aluno/verificar-titular', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await resp.json();

                if (data.ok) {
                    responsibleIdInput.value = data.id;
                    titularNome.textContent = data.first_name + ' ' + data.last_name;
                    titularVerificadoInfo.style.display = 'block';
                    document.getElementById('verificar-form-group').style.display = 'none';
                    titularFeedback.textContent = '';
                    // Dependente: e-mail é opcional
                    emailInput.required = false;
                    emailHintDep.style.display = 'block';
                    mostrarFormulario();
                } else {
                    titularFeedback.textContent = data.mensagem || 'Titular não encontrado.';
                    titularFeedback.className = 'form-text text-danger';
                    btnVerificar.disabled = false;
                }
            } catch (_err) {
                titularFeedback.textContent = 'Erro de conexão. Tente novamente.';
                titularFeedback.className = 'form-text text-danger';
                btnVerificar.disabled = false;
            }
        });

        titularEmailInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); btnVerificar.click(); }
        });

        // Botão "trocar" titular
        btnTrocarTitular.addEventListener('click', function () {
            responsibleIdInput.value = '';
            titularVerificadoInfo.style.display = 'none';
            document.getElementById('verificar-form-group').style.display = 'block';
            titularEmailInput.value = '';
            titularFeedback.textContent = '';
            btnVerificar.disabled = false;
            formFieldsContainer.style.display = 'none';
            emailInput.required = true;
            emailHintDep.style.display = 'none';
        });
    })();
</script>
{{/unless}}