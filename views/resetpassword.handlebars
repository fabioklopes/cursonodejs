<div class="container py-4" style="max-width: 520px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <h3 class="mb-2">{{pageTitle}}</h3>
                <p class="text-secondary mb-0">
                    {{#if resetMode}}
                    Defina uma nova senha para continuar.
                    {{else}}
                    Informe seu e-mail cadastrado para receber o link de redefinição.
                    {{/if}}
                </p>
            </div>

            {{#if statusMessages}}
            {{#each statusMessages}}
            <div class="alert alert-{{variant}} mb-3" role="alert">
                {{#if title}}
                <strong>{{title}}</strong><br>
                {{/if}}
                {{#if paragraphs}}
                {{#each paragraphs}}
                <p class="mb-2">{{this}}</p>
                {{/each}}
                {{else}}
                <span>{{text}}</span>
                {{/if}}
            </div>
            {{/each}}
            {{/if}}

            {{#if requestMode}}
            <form action="/auth/forgot-password" method="POST">
                <div class="mb-3">
                    <label for="email" class="form-label">E-mail cadastrado</label>
                    <input type="email" class="form-control" id="email" name="email" value="{{email}}" required>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Enviar link de redefinição
                </button>
            </form>
            {{/if}}

            {{#if resetMode}}
            <form action="/auth/reset-password" method="POST">
                <input type="hidden" name="email" value="{{email}}">
                <input type="hidden" name="token" value="{{token}}">

                <div class="mb-3">
                    <label for="email-readonly" class="form-label">E-mail</label>
                    <input type="email" class="form-control" id="email-readonly" value="{{email}}" readonly>
                </div>

                <div class="mb-3">
                    <label for="newPassword" class="form-label">Nova senha</label>
                    <input type="password" class="form-control" id="newPassword" name="newPassword" {{#if canSubmitReset}}required{{else}}disabled{{/if}}>
                </div>

                <div class="mb-3">
                    <label for="confirmPassword" class="form-label">Confirmar nova senha</label>
                    <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" {{#if canSubmitReset}}required{{else}}disabled{{/if}}>
                </div>

                <button type="submit" class="btn btn-success w-100" {{#unless canSubmitReset}}disabled{{/unless}}>
                    Salvar nova senha
                </button>
            </form>
            {{/if}}

            {{#if showBackToLogin}}
            <div class="text-center mt-4">
                <a href="/auth/login" class="link-secondary">Voltar para o login</a>
            </div>
            {{/if}}
        </div>
    </div>
</div>