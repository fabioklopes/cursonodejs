{{#if mensagem}}
<div class="alert alert-{{tipoMensagem}} alert-autodismiss" role="alert">
    {{#if (eq tipoMensagem 'danger')}}<i class="fa-solid fa-circle-xmark"></i>{{else}}<i class="fa-solid fa-circle-check"></i>{{/if}} {{mensagem}}
</div>
{{/if}}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div><h1 class="mb-0">Central de Avisos</h1></div>
</div>

<div class="row g-3 mb-3" id="studentMassCardsRow">
    <div class="col-12 col-md-4">
        <button type="button" class="card border-0 shadow-sm h-100 w-100 text-start student-mass-select-card" data-category="novas">
            <div class="card-body">
                <div class="small text-body-secondary text-uppercase">Novas</div>
                <div class="d-flex align-items-center justify-content-between gap-2 mt-1">
                    <div class="display-6 fw-semibold text-primary" id="studentMassNovasCount">0</div>
                    <i class="fa-solid fa-envelope fs-3 text-primary"></i>
                </div>
            </div>
        </button>
    </div>

    <div class="col-12 col-md-4">
        <button type="button" class="card border-0 shadow-sm h-100 w-100 text-start student-mass-select-card" data-category="lidas">
            <div class="card-body">
                <div class="small text-body-secondary text-uppercase">Lidas</div>
                <div class="d-flex align-items-center justify-content-between gap-2 mt-1">
                    <div class="display-6 fw-semibold text-info" id="studentMassLidasCount">0</div>
                    <i class="fa-regular fa-envelope-open fs-3 text-info"></i>
                </div>
            </div>
        </button>
    </div>

    <div class="col-12 col-md-4">
        <button type="button" class="card border-0 shadow-sm h-100 w-100 text-start student-mass-select-card" data-category="antigas">
            <div class="card-body">
                <div class="small text-body-secondary text-uppercase">Antigas</div>
                <div class="d-flex align-items-center justify-content-between gap-2 mt-1">
                    <div class="display-6 fw-semibold text-secondary" id="studentMassAntigasCount">0</div>
                    <i class="fa-solid fa-clock-rotate-left fs-3 text-secondary"></i>
                </div>
            </div>
        </button>
    </div>
</div>



<div id="studentMassMessagesData" class="d-none">
    {{#each mensagens}}
    <div
        class="js-student-message-data"
        data-id="{{id}}"
        data-title="{{title}}"
        data-content="{{content}}"
        data-class-display="{{class_display}}"
        data-created-at-label="{{createdAtLabel}}"
        data-created-at-value="{{createdAtValue}}"
        data-expires-at-label="{{expiresAtLabel}}"
        data-is-read="{{#if isRead}}true{{else}}false{{/if}}"
        data-read-at-label="{{readAtLabel}}"
        data-status-label="{{statusLabel}}"
        data-status-badge="{{statusBadge}}"
    ></div>
    {{/each}}
</div>

<div class="modal fade" id="studentMassListModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="studentMassListModalTitle">Mensagens</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div id="studentMassListEmpty" class="text-body-secondary d-none">Nenhuma mensagem nesta categoria.</div>
                <div id="studentMassList" class="student-mass-list"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="studentMassDetailModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="studentMassDetailTitle">Mensagem</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge" id="studentMassDetailStatusBadge"></span>
                    <span class="badge" id="studentMassDetailReadBadge"></span>
                </div>

                <div class="mb-3">
                    <div class="small text-body-secondary mb-1">Mensagem</div>
                    <div class="fs-6" id="studentMassDetailContent"></div>
                </div>

                <div class="row g-3 small text-body-secondary mb-3">
                    <div class="col-12 col-md-6">
                        <div><strong>Turma:</strong> <span id="studentMassDetailClass"></span></div>
                        <div><strong>Data de criação:</strong> <span id="studentMassDetailCreatedAt"></span></div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div><strong>Expira em:</strong> <span id="studentMassDetailExpiresAt"></span></div>
                        <div id="studentMassDetailReadAtRow" class="d-none"><strong>Visualizada em:</strong> <span id="studentMassDetailReadAt"></span></div>
                    </div>
                </div>

                <div class="d-flex flex-column gap-2 justify-content-center">
                    <button type="button" class="btn btn-outline-primary btn-sm" id="studentMassDetailUnreadButton">
                        <i class="fa-solid fa-envelope"></i> Marcar como não lido
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="studentMassDetailHideButton">
                        <i class="fa-solid fa-eye-slash"></i> Remover da minha área de mensagens
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .student-mass-select-card {
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .student-mass-select-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.12);
    }

    .student-mass-list {
        max-height: 55vh;
        overflow-y: auto;
        display: grid;
        gap: 0.75rem;
    }

    .student-mass-list-item {
        display: block;
        border: 1px solid var(--bs-border-color);
        border-radius: 0.5rem;
        padding: 0.75rem;
        background-color: var(--bs-body-bg);
        text-align: left;
        width: 100%;
        max-width: 100%;
        overflow: hidden;
    }

    .student-mass-list-title {
        font-weight: 700;
        display: block;
        max-width: 100%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .student-mass-list-preview {
        color: var(--bs-secondary-color);
        display: block;
        max-width: 100%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

<script>
    (function() {
        function parseMessageElements() {
            const elements = Array.from(document.querySelectorAll('.js-student-message-data'));
            return elements.map((el) => {
                const createdAtRaw = el.getAttribute('data-created-at-value');
                const createdAtDate = createdAtRaw ? new Date(createdAtRaw) : null;

                return {
                    id: Number(el.getAttribute('data-id')),
                    title: el.getAttribute('data-title') || '',
                    content: el.getAttribute('data-content') || '',
                    classDisplay: el.getAttribute('data-class-display') || '',
                    createdAtLabel: el.getAttribute('data-created-at-label') || '',
                    createdAtDate,
                    expiresAtLabel: el.getAttribute('data-expires-at-label') || '',
                    isRead: el.getAttribute('data-is-read') === 'true',
                    readAtLabel: el.getAttribute('data-read-at-label') || '',
                    statusLabel: el.getAttribute('data-status-label') || 'Ativo',
                    statusBadge: el.getAttribute('data-status-badge') || 'primary'
                };
            }).filter((msg) => Number.isInteger(msg.id) && msg.id > 0);
        }

        function isOldMessage(message) {
            return message.statusLabel === 'Expirado';
        }

        function getCategoryMessages(messages, category) {
            if (category === 'novas') {
                return messages.filter((msg) => !msg.isRead && !isOldMessage(msg));
            }

            if (category === 'lidas') {
                return messages.filter((msg) => msg.isRead && !isOldMessage(msg));
            }

            if (category === 'antigas') {
                return messages.filter((msg) => isOldMessage(msg));
            }

            return [];
        }

        function updateStudentMassMessageBellSafe(unreadCount) {
            if (typeof updateStudentMassMessageBell === 'function') {
                updateStudentMassMessageBell(unreadCount);
            }
        }

        async function postMarkAsRead(messageId) {
            const response = await fetch(`/mensagens/mestre/${messageId}/lida`, { method: 'POST' });
            if (!response.ok) throw new Error('Falha ao registrar leitura.');
            return response.json();
        }

        async function postMarkAsUnread(messageId) {
            const response = await fetch(`/mensagens/mestre/${messageId}/naoLida`, { method: 'POST' });
            if (!response.ok) throw new Error('Falha ao marcar como não lida.');
            return response.json();
        }

        async function postHideMessage(messageId) {
            const response = await fetch('/mensagens/ocultar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message_id: messageId })
            });

            if (!response.ok) throw new Error('Falha ao ocultar mensagem.');
            return response.json();
        }

        function initMensagensMestrePage() {
            if (typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                return;
            }

            const cards = Array.from(document.querySelectorAll('.student-mass-select-card'));
            const emptyStateElement = document.getElementById('studentMassEmptyState');
            const listModalElement = document.getElementById('studentMassListModal');
            const detailModalElement = document.getElementById('studentMassDetailModal');

            if (!listModalElement || !detailModalElement) {
                return;
            }

            const listModal = bootstrap.Modal.getOrCreateInstance(listModalElement);
            const detailModal = bootstrap.Modal.getOrCreateInstance(detailModalElement);

            const listTitle = document.getElementById('studentMassListModalTitle');
            const listContainer = document.getElementById('studentMassList');
            const listEmpty = document.getElementById('studentMassListEmpty');

            const countNovas = document.getElementById('studentMassNovasCount');
            const countLidas = document.getElementById('studentMassLidasCount');
            const countAntigas = document.getElementById('studentMassAntigasCount');

            const detailTitle = document.getElementById('studentMassDetailTitle');
            const detailStatusBadge = document.getElementById('studentMassDetailStatusBadge');
            const detailReadBadge = document.getElementById('studentMassDetailReadBadge');
            const detailContent = document.getElementById('studentMassDetailContent');
            const detailClass = document.getElementById('studentMassDetailClass');
            const detailCreatedAt = document.getElementById('studentMassDetailCreatedAt');
            const detailExpiresAt = document.getElementById('studentMassDetailExpiresAt');
            const detailReadAtRow = document.getElementById('studentMassDetailReadAtRow');
            const detailReadAt = document.getElementById('studentMassDetailReadAt');
            const detailUnreadButton = document.getElementById('studentMassDetailUnreadButton');
            const detailHideButton = document.getElementById('studentMassDetailHideButton');

            let messages = parseMessageElements();
            let selectedCategory = 'novas';
            let selectedMessageId = null;
            let pendingMessageIds = new Set();

            function findMessageById(messageId) {
                return messages.find((msg) => msg.id === messageId) || null;
            }

            function getUnreadCount() {
                return messages.filter((msg) => !msg.isRead).length;
            }

            function getCounts() {
                return {
                    novas: getCategoryMessages(messages, 'novas').length,
                    lidas: getCategoryMessages(messages, 'lidas').length,
                    antigas: getCategoryMessages(messages, 'antigas').length,
                    total: messages.length,
                    unread: getUnreadCount()
                };
            }

            function updateCardsAndEmptyState() {
                const counts = getCounts();

                if (countNovas) countNovas.textContent = String(counts.novas);
                if (countLidas) countLidas.textContent = String(counts.lidas);
                if (countAntigas) countAntigas.textContent = String(counts.antigas);

                if (emptyStateElement) {
                    emptyStateElement.classList.toggle('d-none', counts.total > 0);
                }

                updateStudentMassMessageBellSafe(counts.unread);

                const menuBadge = document.getElementById('studentMassMessageMenuBadge');
                if (menuBadge) {
                    menuBadge.textContent = String(counts.unread);
                    menuBadge.classList.toggle('d-none', counts.unread === 0);
                }
            }

            function renderListModal(category) {
                selectedCategory = category;
                const items = getCategoryMessages(messages, category);
                const titles = {
                    novas: 'Mensagens Novas',
                    lidas: 'Mensagens Lidas',
                    antigas: 'Mensagens Antigas'
                };

                if (listTitle) {
                    listTitle.textContent = titles[category] || 'Mensagens';
                }

                if (!listContainer) {
                    return;
                }

                listContainer.innerHTML = '';

                if (listEmpty) {
                    listEmpty.classList.toggle('d-none', items.length > 0);
                }

                items.forEach((message) => {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'student-mass-list-item';
                    btn.setAttribute('data-message-id', String(message.id));

                    const title = document.createElement('span');
                    title.className = 'student-mass-list-title';
                    title.textContent = message.title;

                    const preview = document.createElement('span');
                    preview.className = 'student-mass-list-preview';
                    preview.textContent = message.content;

                    btn.appendChild(title);
                    btn.appendChild(preview);

                    btn.addEventListener('click', async function() {
                        selectedMessageId = message.id;
                        const current = findMessageById(message.id);
                        if (!current) {
                            return;
                        }

                        if (!current.isRead && !pendingMessageIds.has(current.id)) {
                            pendingMessageIds.add(current.id);
                            try {
                                const payload = await postMarkAsRead(current.id);
                                current.isRead = true;
                                current.readAtLabel = payload.readAtLabel || current.readAtLabel;
                            } catch (error) {
                                console.error('Erro ao marcar leitura ao abrir detalhe:', error);
                            } finally {
                                pendingMessageIds.delete(current.id);
                            }
                        }

                        renderDetailModal(current);
                        updateCardsAndEmptyState();
                        renderListModal(selectedCategory);
                        detailModal.show();
                    });

                    listContainer.appendChild(btn);
                });

                listModal.show();
            }

            function renderDetailModal(message) {
                if (!message) {
                    return;
                }

                if (detailTitle) detailTitle.textContent = message.title;
                if (detailContent) detailContent.textContent = message.content;
                if (detailClass) detailClass.textContent = message.classDisplay;
                if (detailCreatedAt) detailCreatedAt.textContent = message.createdAtLabel;
                if (detailExpiresAt) detailExpiresAt.textContent = message.expiresAtLabel;

                if (detailStatusBadge) {
                    detailStatusBadge.className = `badge text-bg-${message.statusBadge}`;
                    detailStatusBadge.textContent = message.statusLabel;
                }

                if (detailReadBadge) {
                    detailReadBadge.className = message.isRead ? 'badge text-bg-secondary' : 'badge text-bg-danger';
                    detailReadBadge.textContent = message.isRead ? 'Lida' : 'Nova';
                }

                if (detailReadAtRow) {
                    detailReadAtRow.classList.toggle('d-none', !message.isRead);
                }

                if (detailReadAt) {
                    detailReadAt.textContent = message.readAtLabel || '';
                }

                if (detailUnreadButton) {
                    detailUnreadButton.classList.toggle('d-none', !message.isRead);
                }
            }

            if (detailUnreadButton) {
                detailUnreadButton.addEventListener('click', async function() {
                    if (!selectedMessageId || pendingMessageIds.has(selectedMessageId)) {
                        return;
                    }

                    const current = findMessageById(selectedMessageId);
                    if (!current || !current.isRead) {
                        return;
                    }

                    pendingMessageIds.add(selectedMessageId);
                    detailUnreadButton.disabled = true;

                    try {
                        const payload = await postMarkAsUnread(selectedMessageId);
                        current.isRead = false;
                        current.readAtLabel = '';

                        renderDetailModal(current);
                        updateCardsAndEmptyState();
                        renderListModal(selectedCategory);

                        if (payload && typeof payload.unreadCount === 'number') {
                            updateStudentMassMessageBellSafe(payload.unreadCount);
                        }
                    } catch (error) {
                        console.error('Erro ao marcar como não lida:', error);
                    } finally {
                        pendingMessageIds.delete(selectedMessageId);
                        detailUnreadButton.disabled = false;
                    }
                });
            }

            if (detailHideButton) {
                detailHideButton.addEventListener('click', async function() {
                    if (!selectedMessageId || pendingMessageIds.has(selectedMessageId)) {
                        return;
                    }

                    const current = findMessageById(selectedMessageId);
                    if (!current) {
                        return;
                    }

                    pendingMessageIds.add(selectedMessageId);
                    detailHideButton.disabled = true;

                    try {
                        const payload = await postHideMessage(selectedMessageId);
                        messages = messages.filter((msg) => msg.id !== selectedMessageId);
                        selectedMessageId = null;

                        detailModal.hide();
                        updateCardsAndEmptyState();
                        renderListModal(selectedCategory);

                        if (payload && typeof payload.unreadCount === 'number') {
                            updateStudentMassMessageBellSafe(payload.unreadCount);
                        }
                    } catch (error) {
                        console.error('Erro ao remover mensagem da area:', error);
                    } finally {
                        pendingMessageIds.delete(current.id);
                        detailHideButton.disabled = false;
                    }
                });
            }

            cards.forEach((card) => {
                card.addEventListener('click', function() {
                    const category = card.getAttribute('data-category') || 'novas';
                    renderListModal(category);
                });
            });

            listModalElement.addEventListener('hidden.bs.modal', function() {
                if (detailModalElement.classList.contains('show')) {
                    return;
                }
                selectedMessageId = null;
            });

            updateCardsAndEmptyState();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initMensagensMestrePage);
        } else {
            initMensagensMestrePage();
        }
    })();
</script>
