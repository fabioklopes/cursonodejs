{{#if mensagem}}
<div class="alert alert-{{tipoMensagem}} alert-autodismiss" role="alert">
    {{#if (eq tipoMensagem 'danger')}}<i class="fa-solid fa-circle-xmark"></i>{{else}}<i class="fa-solid fa-circle-check"></i>{{/if}} {{mensagem}}
</div>
{{/if}}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="mb-0">Mensagens do Mestre</h1>
    </div>
    <a href="/dashboard" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left"></i> Voltar
    </a>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-body-secondary text-uppercase">Ativas</div>
                <div class="display-6 fw-semibold" id="studentMassTotalCountValue">{{totalMensagens}}</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-body-secondary text-uppercase">Não lidas</div>
                <div class="display-6 fw-semibold text-danger" id="studentMassUnreadCountValue">{{totalNaoLidas}}</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-body-secondary text-uppercase">Lidas</div>
                <div class="display-6 fw-semibold text-secondary" id="studentMassReadCountValue">{{totalLidas}}</div>
            </div>
        </div>
    </div>
</div>

<div class="accordion {{#unless mensagens.length}}d-none{{/unless}}" id="mensagensMestreAccordion">
    {{#each mensagens}}
    <div class="accordion-item border-0 shadow-sm mb-3 student-mass-message-item {{#unless isRead}}student-mass-message-item-unread{{/unless}}" data-message-id="{{id}}" data-is-read="{{#if isRead}}true{{else}}false{{/if}}">
        <h2 class="accordion-header">
            <button class="accordion-button collapsed gap-3" type="button" data-bs-toggle="collapse" data-bs-target="#mensagemMestreCollapse{{id}}" aria-expanded="false" aria-controls="mensagemMestreCollapse{{id}}">
                <span class="d-flex flex-column flex-lg-row align-items-lg-center gap-2 flex-grow-1 text-start">
                    <span class="fw-semibold">{{title}}</span>
                    <span class="d-flex flex-wrap gap-2 align-items-center">
                        <span class="badge text-bg-{{statusBadge}}">{{statusLabel}}</span>
                        <span class="badge text-bg-{{readStateBadge}} js-read-state-badge">{{readStateLabel}}</span>
                    </span>
                </span>
            </button>
        </h2>
        <div id="mensagemMestreCollapse{{id}}" class="accordion-collapse collapse" data-bs-parent="#mensagensMestreAccordion">
            <div class="accordion-body">
                <div class="mb-3">
                    <div class="small text-body-secondary mb-1">Mensagem</div>
                    <div class="fs-6">{{content}}</div>
                </div>

                <div class="row g-3 small text-body-secondary mb-3">
                    <div class="col-12 col-md-6">
                        <div><strong>Turma:</strong> {{class_display}}</div>
                        <div><strong>Data de criação:</strong> {{createdAtLabel}}</div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div><strong>Expira em:</strong> {{expiresAtLabel}}</div>
                        <div class="js-read-at-wrapper {{#unless isRead}}d-none{{/unless}}"><strong>Visualizada em:</strong> <span class="js-read-at-label">{{readAtLabel}}</span></div>
                    </div>
                </div>

                <div class="d-flex flex-column gap-2 justify-content-center">
                    <button type="button" class="btn btn-outline-primary btn-sm js-mark-unread-button">
                        <i class="fa-solid fa-envelope"></i> Marcar como não lido
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm js-hide-message-button">
                        <i class="fa-solid fa-eye-slash"></i> Remover da minha área de mensagens
                    </button>
                </div>
            </div>
        </div>
    </div>
    {{/each}}
</div>

<div class="card border-0 shadow-sm {{#if mensagens.length}}d-none{{/if}}" id="studentMassEmptyState">
    <div class="card-body py-4 text-center text-body-secondary">
        <i class="fa-solid fa-bell-slash fs-2 d-block mb-3"></i>
        Nenhuma mensagem ativa do mestre para você neste momento.
