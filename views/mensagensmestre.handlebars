                                        emptyStateElement.classList.toggle('d-none', normalizedTotalCount > 0);
                                    }
<style>
    .student-mass-message-item-unread {
        border-left: 0.3rem solid var(--bs-primary);
    }

    .student-mass-message-item .accordion-button {
        background: transparent;
        box-shadow: none;
    }

    .student-mass-message-item .accordion-button:not(.collapsed) {
        color: inherit;
        background-color: rgba(13, 110, 253, 0.04);
    }
</style>

<script>
    (function() {
        function initMensagensMestrePage() {
            const totalElement = document.getElementById('studentMassTotalCountValue');
            const unreadElement = document.getElementById('studentMassUnreadCountValue');
            const readElement = document.getElementById('studentMassReadCountValue');
            const accordionElement = document.getElementById('mensagensMestreAccordion');
            const emptyStateElement = document.getElementById('studentMassEmptyState');
            const items = Array.from(document.querySelectorAll('.student-mass-message-item'));
            const pendingIds = new Set();

            if (items.length === 0 || typeof bootstrap === 'undefined') {
                return;
            }

            function updateCounters(totalCount, unreadCount) {
                const normalizedTotalCount = Math.max(Number(totalCount) || 0, 0);
                const normalizedUnreadCount = Math.max(Number(unreadCount) || 0, 0);
                const readCount = Math.max(normalizedTotalCount - normalizedUnreadCount, 0);

                if (totalElement) totalElement.textContent = String(normalizedTotalCount);
                if (unreadElement) unreadElement.textContent = String(normalizedUnreadCount);
                if (readElement) readElement.textContent = String(readCount);

                if (typeof updateStudentMassMessageBell === 'function') {
                    updateStudentMassMessageBell(normalizedUnreadCount);
                }

                if (accordionElement) {
                    accordionElement.classList.toggle('d-none', normalizedTotalCount === 0);
                }

                if (emptyStateElement) {
                    emptyStateElement.classList.toggle('d-none', normalizedTotalCount > 0);
                }
            }

            async function markAsRead(item) {
                const messageId = item.getAttribute('data-message-id');
                if (!messageId || item.getAttribute('data-is-read') === 'true' || pendingIds.has(messageId)) {
                    return;
                }

                pendingIds.add(messageId);

                try {
                    const response = await fetch(`/mensagens/mestre/${messageId}/lida`, {
                        method: 'POST'
                    });

                    if (!response.ok) {
                        throw new Error('Falha ao registrar leitura da mensagem.');
                    }

                    const payload = await response.json();
                    item.setAttribute('data-is-read', 'true');
                    item.classList.remove('student-mass-message-item-unread');

                    const readStateBadge = item.querySelector('.js-read-state-badge');
                    if (readStateBadge) {
                        readStateBadge.textContent = 'Lida';
                        readStateBadge.className = 'badge text-bg-secondary js-read-state-badge';
                    }

                    const readAtWrapper = item.querySelector('.js-read-at-wrapper');
                    const readAtLabel = item.querySelector('.js-read-at-label');

                    if (readAtWrapper) {
                        readAtWrapper.classList.remove('d-none');
                    }

                    if (readAtLabel && payload.readAtLabel) {
                        readAtLabel.textContent = payload.readAtLabel;
                    }

                    if (typeof payload.unreadCount === 'number') {
                        const currentTotalCount = Number(totalElement ? totalElement.textContent : items.length) || items.length;
                        updateCounters(currentTotalCount, payload.unreadCount);
                    }
                } catch (error) {
                    console.error('Erro ao marcar mensagem como lida:', error);
                } finally {
                    pendingIds.delete(messageId);
                }
            }

            async function markAsUnread(item, button) {
                const messageId = item.getAttribute('data-message-id');
                if (!messageId || item.getAttribute('data-is-read') === 'false' || pendingIds.has(messageId)) {
                    return;
                }

                pendingIds.add(messageId);
                if (button) {
                    button.disabled = true;
                }

                try {
                    const response = await fetch(`/mensagens/mestre/${messageId}/naoLida`, {
                        method: 'POST'
                    });

                    if (!response.ok) {
                        throw new Error('Falha ao marcar mensagem como não lida.');
                    }

                    const payload = await response.json();
                    item.setAttribute('data-is-read', 'false');
                    item.classList.add('student-mass-message-item-unread');

                    const readStateBadge = item.querySelector('.js-read-state-badge');
                    if (readStateBadge) {
                        readStateBadge.textContent = 'Nova';
                        readStateBadge.className = 'badge text-bg-info js-read-state-badge';
                    }

                    const readAtWrapper = item.querySelector('.js-read-at-wrapper');
                    if (readAtWrapper) {
                        readAtWrapper.classList.add('d-none');
                    }

                    if (typeof payload.unreadCount === 'number') {
                        const currentTotalCount = Number(totalElement ? totalElement.textContent : items.length) || items.length;
                        updateCounters(currentTotalCount, payload.unreadCount);
                    }
                } catch (error) {
                    console.error('Erro ao marcar mensagem como não lida:', error);
                    if (button) {
                        button.disabled = false;
                    }
                } finally {
                    pendingIds.delete(messageId);
                }
            }

            async function hideMessage(item, button) {
                const messageId = item.getAttribute('data-message-id');
                if (!messageId || pendingIds.has(messageId)) {
                    return;
                }

                pendingIds.add(messageId);
                if (button) {
                    button.disabled = true;
                }

                try {
                    const response = await fetch('/mensagens/ocultar', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            message_id: messageId
                        })
                    });

                    if (!response.ok) {
                        throw new Error('Falha ao ocultar a mensagem.');
                    }

                    const payload = await response.json();
                    item.remove();

                    const totalCount = typeof payload.totalCount === 'number'
                        ? payload.totalCount
                        : Math.max((Number(totalElement ? totalElement.textContent : 0) || 0) - 1, 0);
                    const unreadCount = typeof payload.unreadCount === 'number'
                        ? payload.unreadCount
                        : Math.max(Number(unreadElement ? unreadElement.textContent : 0) || 0, 0);

                    updateCounters(totalCount, unreadCount);
                } catch (error) {
                    console.error('Erro ao ocultar mensagem do mestre:', error);
                    if (button) {
                        button.disabled = false;
                    }
                } finally {
                    pendingIds.delete(messageId);
                }
            }

            items.forEach((item) => {
                const collapseElement = item.querySelector('.accordion-collapse');
                const unreadButton = item.querySelector('.js-mark-unread-button');
                const hideButton = item.querySelector('.js-hide-message-button');

                if (!collapseElement) {
                    return;
                }

                collapseElement.addEventListener('show.bs.collapse', function() {
                    markAsRead(item);
                });

                if (unreadButton) {
                    unreadButton.addEventListener('click', function() {
                        markAsUnread(item, unreadButton);
                    });
                }

                if (hideButton) {
                    hideButton.addEventListener('click', function() {
                        hideMessage(item, hideButton);
                    });
                }
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initMensagensMestrePage);
        } else {
            initMensagensMestrePage();
        }
    })();
</script>