{{#if mensagem}}
    <div class="alert alert-primary text-center alert-autodismiss" role="alert">
        {{mensagem}}
    </div>
{{/if}}

<h1>Página Aluno</h1>
<table class="table table-striped align-middle table-mobile-stack">
    <thead>
        <tr>
            <th>Nome</th>
            <th>E-mail</th>
            <th>Perfil</th>
            <th>Status</th>
            <th>WhatsApp</th>
            <th>Aniversário</th>
            <th>Faixa</th>
            <th>Wagi</th>
            <th>Zubon</th>
            <th>Obi</th>
            <th>Dependente</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        {{#each usuarios}}
            <tr>
                <td data-label="Nome">{{first_name}} {{last_name}}</td>
                <td data-label="E-mail">{{email}}</td>
                <td data-label="Perfil">{{role_label}}</td>
                <td data-label="Status">{{user_status_label}}</td>
                <td data-label="WhatsApp">{{phone}}</td>
                <td data-label="Aniversário">{{birth_date}}</td>
                <td data-label="Faixa">{{actual_belt}}</td>
                <td data-label="Wagi">{{wagi_size}}</td>
                <td data-label="Zubon">{{zubon_size}}</td>
                <td data-label="Obi">{{obi_size}}</td>
                <td data-label="Dependente">{{responsible_id}}</td>
                <td data-label="Ações">
                    <a href="/aluno/editar/{{id}}" class="btn btn-sm btn-outline-primary">Editar</a>
                    {{#if can_approve}}
                        <a href="/aluno/status/{{id}}" class="btn btn-sm btn-success">Aprovar</a>
                        <a href="/aluno/status/negar/{{id}}" class="btn btn-sm btn-outline-danger">Negar</a>
                    {{/if}}
                </td>
            </tr>
        {{/each}}
    </tbody>
</table>