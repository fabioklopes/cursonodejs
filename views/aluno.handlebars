{{#if mensagem}}
    <div class="alert {{#if (eq tipoMensagem 'sucesso')}}alert-success{{else}}{{#if (eq tipoMensagem 'erro')}}alert-danger{{else}}{{#if (eq tipoMensagem 'desconformidade')}}alert-warning{{else}}alert-primary{{/if}}{{/if}}{{/if}} text-center alert-autodismiss" role="alert">
        {{#if (eq tipoMensagem 'sucesso')}}
        <i class="fa-solid fa-circle-check"></i>
        {{else}}
        {{#if (eq tipoMensagem 'erro')}}
        <i class="fa-solid fa-circle-xmark"></i>
        {{else}}
        {{#if (eq tipoMensagem 'desconformidade')}}
        <i class="fa-solid fa-triangle-exclamation"></i>
        {{/if}}{{/if}}{{/if}}
        {{mensagem}}
        {{#if (eq tipoMensagem 'sucesso')}}
        <div class="mt-2 small" id="redirectCountdown">Redirecionando em <span id="countdownNumber">3</span>s...</div>
        {{/if}}
    </div>
{{/if}}

<h1 class="mb-4">Página Aluno</h1>
<style>
    .aluno-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--bs-border-color-translucent);
    }

    .aluno-link {
        color: inherit;
        text-decoration: none;
        cursor: pointer;
        text-align: left;
    }

    .aluno-link:hover {
        text-decoration: underline;
    }

    .modal-scroll-interno {
        max-height: 55vh;
        overflow-y: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .modal-scroll-interno::-webkit-scrollbar {
        width: 0;
        height: 0;
    }

    .aluno-detail-label {
        font-weight: 600;
        color: var(--bs-secondary-color);
    }

    .aluno-pagination-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        max-width: 100%;
    }

    .aluno-pagination-wrapper small {
        text-align: center;
    }

    .aluno-pagination-wrapper > * {
        min-width: 0;
    }

    .aluno-pagination-nav {
        display: flex;
        justify-content: center;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
    }

    .aluno-pagination-nav .pagination {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        width: auto;
        margin-bottom: 0;
    }

    @media (max-width: 768px) {
        .aluno-pagination-nav .page-link {
            padding: 0.25rem 0.5rem;
            font-size: 0.85rem;
        }
    }

    .form-check.form-switch.text-success .form-check-input:checked {
        background-color: var(--bs-success);
        border-color: var(--bs-success);
    }

    .form-check.form-switch.text-danger .form-check-input:checked {
        background-color: var(--bs-danger);
        border-color: var(--bs-danger);
    }
</style>

<form id="alunoSearchForm" method="GET" action="/aluno" class="mb-3">
    <label for="alunoSearchInput" class="form-label">Buscar aluno</label>
    <input
        type="text"
        id="alunoSearchInput"
        name="q"
        class="form-control"
        placeholder="Pesquisar por nome, e-mail ou telefone"
        value="{{searchTerm}}"
        autocomplete="off"
    >
</form>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Alunos</th>
        </tr>
    </thead>
    <tbody>
        {{#if usuarios.length}}
        {{#each usuarios}}
            <tr>
                <td>
                    <button
                        type="button"
                        class="aluno-link d-inline-flex align-items-center gap-2 border-0 bg-transparent p-0 w-100"
                        data-bs-toggle="modal"
                        data-bs-target="#alunoModal"
                        data-id="{{id}}"
                        data-first-name="{{first_name}}"
                        data-last-name="{{last_name}}"
                        data-email="{{email}}"
                        data-role="{{role_label}}"
                        data-status="{{user_status_label}}"
                        data-status-code="{{user_status}}"
                        data-phone="{{formatPhone phone}}"
                        data-birth-date="{{formatDate birth_date}}"
                        data-belt="{{actual_belt}}"
                        data-degree="{{actual_degree}}"
                        data-belt-label="{{belt_label}}"
                        data-degree-label="{{degree_label}}"
                        data-belt-summary="{{belt_summary_label}}"
                        data-belt-image="{{belt_image_path}}"
                        data-wagi="{{wagi_size}}"
                        data-zubon="{{zubon_size}}"
                        data-obi="{{obi_size}}"
                        data-photo="{{photo}}"
                        {{#if responsavel_dados}}
                        data-responsible-id="{{responsavel_dados.id}}"
                        data-responsible-name="{{responsavel_dados.first_name}} {{responsavel_dados.last_name}}"
                        data-responsible-email="{{responsavel_dados.email}}"
                        data-responsible-role="{{responsavel_dados.role_label}}"
                        data-responsible-phone="{{formatPhone responsavel_dados.phone}}"
                        data-responsible-birth="{{formatDate responsavel_dados.birth_date}}"
                        data-responsible-belt="{{responsavel_dados.actual_belt}}"
                        data-responsible-degree="{{responsavel_dados.actual_degree}}"
                        data-responsible-belt-label="{{responsavel_dados.belt_label}}"
                        data-responsible-belt-summary="{{responsavel_dados.belt_summary_label}}"
                        data-responsible-belt-image="{{responsavel_dados.belt_image_path}}"
                        data-responsible-wagi="{{responsavel_dados.wagi_size}}"
                        data-responsible-zubon="{{responsavel_dados.zubon_size}}"
                        data-responsible-obi="{{responsavel_dados.obi_size}}"
                        data-responsible-photo="{{responsavel_dados.photo}}"
                        {{/if}}
                    >
                        <img src="{{photo}}" alt="Avatar de {{first_name}} {{last_name}}" class="aluno-avatar">
                        <span>{{first_name}} {{last_name}}</span>
                    </button>
                </td>
            </tr>
        {{/each}}
        {{else}}
            <tr>
                <td class="text-center text-body-secondary py-4">
                    Nenhum aluno encontrado para os filtros informados.
                </td>
            </tr>
        {{/if}}
    </tbody>
</table>

<div class="aluno-pagination-wrapper d-flex flex-column align-items-center gap-2 mb-4">
    <small class="text-body-secondary">Total de registros: {{pagination.totalItems}}</small>

    {{#if pagination.totalPages}}
    <nav class="aluno-pagination-nav" aria-label="Paginação de alunos">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item {{#unless pagination.hasPrev}}disabled{{/unless}}">
                <a class="page-link" href="/aluno?page={{pagination.prevPage}}{{#if hasSearchTerm}}&q={{{searchTermEncoded}}}{{/if}}" aria-label="Página anterior">Anterior</a>
            </li>

            {{#each pagination.pageNumbers}}
                <li class="page-item {{#if isCurrent}}active{{/if}}">
                    <a class="page-link" href="/aluno?page={{number}}{{#if ../hasSearchTerm}}&q={{{../searchTermEncoded}}}{{/if}}">{{number}}</a>
                </li>
            {{/each}}

            <li class="page-item {{#unless pagination.hasNext}}disabled{{/unless}}">
                <a class="page-link" href="/aluno?page={{pagination.nextPage}}{{#if hasSearchTerm}}&q={{{searchTermEncoded}}}{{/if}}" aria-label="Próxima página">Próxima</a>
            </li>
        </ul>
    </nav>
    {{/if}}
</div>

<div class="modal fade" id="alunoModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="alunoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom-0">
                <h1 class="modal-title fs-5" id="alunoModalLabel">Dados do aluno</h1>
            </div>

            <div class="modal-body">
                <div class="modal-scroll-interno pe-1">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <img id="modalAlunoPhoto" src="/uploads/users/default.jpg" alt="Avatar do aluno" class="aluno-avatar">
                        <div>
                            <div class="fw-semibold" id="modalAlunoNome">-</div>
                            <small class="text-body-secondary" id="modalAlunoEmail">-</small>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <span class="aluno-detail-label">Perfil:</span>
                            <span id="modalAlunoRole">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">WhatsApp:</span>
                            <span id="modalAlunoPhone">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Aniversário:</span>
                            <span id="modalAlunoBirth">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Faixa:</span>
                            <img id="modalAlunoBeltImage" src="/img/belts/white_0.png" alt="Faixa do aluno" class="img-fluid" style="max-height: 32px;">
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Faixa:</span>
                            <span id="modalAlunoBeltSummary">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Casaco:</span>
                            <span id="modalAlunoWagi">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Calça:</span>
                            <span id="modalAlunoZubon">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Faixa (tamanho):</span>
                            <span id="modalAlunoObi">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Responsável:</span>
                            <span id="modalAlunoResponsible">
                                <a href="#" id="modalAlunoResponsibleLink" class="text-decoration-none">-</a>
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer d-block text-center">
                <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
                    <span class="aluno-detail-label">Status do aluno:</span>
                    <div class="form-check form-switch" id="alunoStatusSwitchContainer">
                        <input class="form-check-input" type="checkbox" id="alunoStatusSwitch" role="switch">
                        <label class="form-check-label" for="alunoStatusSwitch" id="alunoStatusLabel">Ativo</label>
                    </div>
                </div>
                <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal do Responsável -->
<div class="modal fade" id="responsibleModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="responsibleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom-0">
                <h1 class="modal-title fs-5" id="responsibleModalLabel">Dados do responsável</h1>
            </div>

            <div class="modal-body">
                <div class="modal-scroll-interno pe-1">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <img id="modalResponsiblePhoto" src="/uploads/users/default.jpg" alt="Avatar do responsável" class="aluno-avatar">
                        <div>
                            <div class="fw-semibold" id="modalResponsibleNome">-</div>
                            <small class="text-body-secondary" id="modalResponsibleEmail">-</small>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <span class="aluno-detail-label">Perfil:</span>
                            <span id="modalResponsibleRole">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">WhatsApp:</span>
                            <span id="modalResponsiblePhone">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Aniversário:</span>
                            <span id="modalResponsibleBirth">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Faixa:</span>
                            <img id="modalResponsibleBeltImage" src="/img/belts/white_0.png" alt="Faixa do responsável" class="img-fluid" style="max-height: 32px;">
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Faixa:</span>
                            <span id="modalResponsibleBeltSummary">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Casaco:</span>
                            <span id="modalResponsibleWagi">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Calça:</span>
                            <span id="modalResponsibleZubon">-</span>
                        </div>
                        <div class="col-12">
                            <span class="aluno-detail-label">Faixa (tamanho):</span>
                            <span id="modalResponsibleObi">-</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer d-block text-center">
                <hr class="my-2">
                <button type="button" class="btn btn-primary px-4" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        const modal = document.getElementById('alunoModal');
        if (!modal) {
            return;
        }

        let lastTrigger = null;

        const setText = (id, value) => {
            const el = document.getElementById(id);
            if (el) {
                el.textContent = value && String(value).trim() !== '' ? value : '-';
            }
        };

        modal.addEventListener('show.bs.modal', function(event) {
            const trigger = event.relatedTarget;
            lastTrigger = trigger || null;
            if (!trigger) {
                return;
            }

            const firstName = trigger.getAttribute('data-first-name') || '';
            const lastName = trigger.getAttribute('data-last-name') || '';
            const fullName = `${firstName} ${lastName}`.trim();

            const modalPhoto = document.getElementById('modalAlunoPhoto');
            if (modalPhoto) {
                modalPhoto.src = trigger.getAttribute('data-photo') || '/uploads/users/default.jpg';
                modalPhoto.alt = `Avatar de ${fullName || 'aluno'}`;
            }

            setText('modalAlunoNome', fullName || '-');
            setText('modalAlunoEmail', trigger.getAttribute('data-email'));
            setText('modalAlunoRole', trigger.getAttribute('data-role'));
            setText('modalAlunoPhone', trigger.getAttribute('data-phone'));
            setText('modalAlunoBirth', trigger.getAttribute('data-birth-date'));
            setText('modalAlunoBeltSummary', trigger.getAttribute('data-belt-summary'));
            setText('modalAlunoWagi', trigger.getAttribute('data-wagi'));
            setText('modalAlunoZubon', trigger.getAttribute('data-zubon'));
            setText('modalAlunoObi', trigger.getAttribute('data-obi'));

            // Configurar responsável como link
            const responsibleLink = document.getElementById('modalAlunoResponsibleLink');
            const responsibleName = trigger.getAttribute('data-responsible-name');
            if (responsibleName && responsibleLink) {
                responsibleLink.textContent = responsibleName;
                responsibleLink.href = '#';
                responsibleLink.className = 'text-decoration-none text-primary';
                responsibleLink.onclick = function(e) {
                    e.preventDefault();
                    showResponsibleModal(trigger);
                };
            } else if (responsibleLink) {
                responsibleLink.textContent = '-';
                responsibleLink.href = '#';
                responsibleLink.onclick = null;
            }

            // Configurar switch de status
            const statusSwitch = document.getElementById('alunoStatusSwitch');
            const statusLabel = document.getElementById('alunoStatusLabel');
            const statusCode = trigger.getAttribute('data-status-code') || '';
            const switchContainer = document.getElementById('alunoStatusSwitchContainer');
            const alunoId = trigger.getAttribute('data-id');
            
            if (statusSwitch && switchContainer) {
                statusSwitch.checked = statusCode === 'A';
                statusSwitch.dataset.alunoId = alunoId;
                statusSwitch.dataset.originalStatus = statusCode;
                
                // Remover cores anteriores
                switchContainer.classList.remove('text-success', 'text-danger');
                
                // Aplicar cor baseada no status
                if (statusCode === 'A') {
                    statusLabel.textContent = 'Ativo';
                    switchContainer.classList.add('text-success');
                } else if (statusCode === 'C') {
                    statusLabel.textContent = 'Cancelado';
                    switchContainer.classList.add('text-danger');
                } else {
                    statusLabel.textContent = 'Pendente';
                }
            }

            const modalBeltImage = document.getElementById('modalAlunoBeltImage');
            if (modalBeltImage) {
                const beltImagePath = trigger.getAttribute('data-belt-image') || '/img/belts/white_0.png';
                const beltLabel = trigger.getAttribute('data-belt-label') || 'Faixa';
                const beltValue = trigger.getAttribute('data-belt') || 'white';

                modalBeltImage.onerror = function() {
                    this.onerror = null;
                    this.src = `/img/belts/${beltValue}_0.png`;
                };
                modalBeltImage.src = beltImagePath;
                modalBeltImage.alt = `Faixa ${beltLabel}`;
            }
        });

        modal.addEventListener('hide.bs.modal', function() {
            const focusedElement = document.activeElement;
            if (focusedElement && modal.contains(focusedElement) && typeof focusedElement.blur === 'function') {
                focusedElement.blur();
            }
        });

        modal.addEventListener('hidden.bs.modal', function() {
            if (lastTrigger && document.contains(lastTrigger) && typeof lastTrigger.focus === 'function') {
                lastTrigger.focus();
            }
        });

        // Listener para o switch de ativação/desativação
        const statusSwitch = document.getElementById('alunoStatusSwitch');
        if (statusSwitch) {
            statusSwitch.addEventListener('change', async function() {
                const alunoId = this.dataset.alunoId;
                const originalStatus = this.dataset.originalStatus;
                let newStatus;

                // Determinar novo status baseado na ação do switch
                if (this.checked) {
                    newStatus = 'A'; // Checkbox marcado = Ativo
                } else {
                    newStatus = originalStatus === 'A' ? 'C' : 'A'; // Desmarcado
                }

                try {
                    const response = await fetch(`/aluno/status/${alunoId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ newStatus })
                    });

                    if (!response.ok) {
                        const error = await response.json();
                        throw new Error(error.error || 'Erro ao atualizar status');
                    }

                    const result = await response.json();
                    
                    // Fechar modal para recarregar dados
                    const modal = bootstrap.Modal.getInstance(document.getElementById('alunoModal'));
                    if (modal) {
                        modal.hide();
                    }
                    
                    // Recarregar a página após 500ms para permitir o modal fechar
                    setTimeout(() => {
                        location.reload();
                    }, 500);
                } catch (error) {
                    console.error('Erro:', error);
                    alert('Erro ao atualizar status do aluno: ' + error.message);
                    this.checked = originalStatus === 'A';
                }
            });
        }
    })();

    // Modal do responsável
    function showResponsibleModal(trigger) {
        const responsibleModal = document.getElementById('responsibleModal');
        if (!responsibleModal) return;

        const setText = (id, value) => {
            const el = document.getElementById(id);
            if (el) {
                el.textContent = value && String(value).trim() !== '' ? value : '-';
            }
        };

        const responsibleName = trigger.getAttribute('data-responsible-name');
        const responsibleEmail = trigger.getAttribute('data-responsible-email');
        const responsibleRole = trigger.getAttribute('data-responsible-role') || '-';
        const responsiblePhone = trigger.getAttribute('data-responsible-phone');
        const responsibleBirth = trigger.getAttribute('data-responsible-birth');
        const responsiblePhoto = trigger.getAttribute('data-responsible-photo') || '/uploads/users/default.jpg';
        const responsibleBeltLabel = trigger.getAttribute('data-responsible-belt-label') || 'Faixa';
        const responsibleBeltSummary = trigger.getAttribute('data-responsible-belt-summary');
        const responsibleBeltImagePath = trigger.getAttribute('data-responsible-belt-image') || '/img/belts/white_0.png';
        const responsibleBelt = trigger.getAttribute('data-responsible-belt') || 'white';
        const responsibleWagi = trigger.getAttribute('data-responsible-wagi');
        const responsibleZubon = trigger.getAttribute('data-responsible-zubon');
        const responsibleObi = trigger.getAttribute('data-responsible-obi');

        const modalPhoto = document.getElementById('modalResponsiblePhoto');
        if (modalPhoto) {
            modalPhoto.src = responsiblePhoto;
            modalPhoto.alt = `Avatar de ${responsibleName || 'responsável'}`;
        }

        setText('modalResponsibleNome', responsibleName || '-');
        setText('modalResponsibleEmail', responsibleEmail);
        setText('modalResponsibleRole', responsibleRole);
        setText('modalResponsiblePhone', responsiblePhone);
        setText('modalResponsibleBirth', responsibleBirth);
        setText('modalResponsibleBeltSummary', responsibleBeltSummary);
        setText('modalResponsibleWagi', responsibleWagi);
        setText('modalResponsibleZubon', responsibleZubon);
        setText('modalResponsibleObi', responsibleObi);

        const modalBeltImage = document.getElementById('modalResponsibleBeltImage');
        if (modalBeltImage) {
            modalBeltImage.onerror = function() {
                this.onerror = null;
                this.src = `/img/belts/${responsibleBelt}_0.png`;
            };
            modalBeltImage.src = responsibleBeltImagePath;
            modalBeltImage.alt = `Faixa ${responsibleBeltLabel}`;
        }

        const bsModal = new bootstrap.Modal(responsibleModal);
        bsModal.show();
    }
</script>

<script>

    // Script de countdown para redirecionamento automático em caso de sucesso
    document.addEventListener('DOMContentLoaded', function () {
        const redirectCountdown = document.getElementById('redirectCountdown');
        if (redirectCountdown) {
            const countdownNumber = document.getElementById('countdownNumber');
            const params = new URLSearchParams(window.location.search);
            const redirectUrl = new URLSearchParams(window.location.search).get('redirect');
            
            // Se há redirecionamento programado (sucesso)
            if (redirectUrl) {
                let timeRemaining = 3; // 3 segundos
                
                const countdownInterval = setInterval(function () {
                    timeRemaining--;
                    countdownNumber.textContent = Math.max(0, timeRemaining);
                    
                    if (timeRemaining <= 0) {
                        clearInterval(countdownInterval);
                        // Redireciona para a URL especificada ou volta à página anterior
                        window.location.href = decodeURIComponent(redirectUrl) || '/aluno';
                    }
                }, 1000);
            }
        }
    });
</script>