<!doctype html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="mobile-web-app-capable" content="yes">
        
        <title>Sistema Oss - Gestão de Jiu-jitsu</title>

        <link href="/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
        <link rel="icon" href="/img/logotipo.ico">
        <style>
            .student-message-bell-link {
                position: relative;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 2.5rem;
                height: 2.5rem;
                color: var(--bs-body-color);
                text-decoration: none;
            }

            .student-message-bell-link:hover {
                color: var(--bs-danger);
            }

            .student-message-bell-link.is-idle {
                color: var(--bs-secondary-color);
                opacity: 0.55;
            }

            .student-message-bell-icon {
                font-size: 1.25rem;
                line-height: 1;
            }

            .student-message-bell-badge {
                min-width: 1.2rem;
                font-size: 0.68rem;
            }

            .table-mobile-stack {
                width: 100%;
            }

            .table-mobile-stack td {
                overflow-wrap: anywhere;
            }

            @media (max-width: 768px) {
                .table-mobile-stack thead {
                    display: none;
                }

                .table-mobile-stack,
                .table-mobile-stack tbody,
                .table-mobile-stack tr,
                .table-mobile-stack td {
                    display: block;
                    width: 100%;
                }

                .table-mobile-stack tbody tr {
                    margin-bottom: 1rem;
                    border: 1px solid var(--bs-border-color);
                    border-radius: 0.75rem;
                    background-color: var(--bs-body-bg);
                    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
                    overflow: hidden;
                }

                .table-mobile-stack tbody td {
                    display: flex;
                    justify-content: space-between;
                    gap: 1rem;
                    padding: 0.75rem 1rem;
                    border: 0;
                    border-bottom: 1px solid var(--bs-border-color-translucent);
                    text-align: right;
                }

                .table-mobile-stack tbody td:last-child {
                    border-bottom: 0;
                }

                .table-mobile-stack tbody td::before {
                    content: attr(data-label);
                    font-weight: 600;
                    color: var(--bs-secondary-color);
                    text-align: left;
                    margin-right: 1rem;
                }
            }
        </style>

        <!-- Título do preview -->
        <meta property="og:title" content="CRTN Belém - Jiu-jitsu ADPM">

        <!-- Descrição do preview -->
        <meta property="og:description" content="Sistema gerenciador de alunos, turmas e controle de presenças">

        <!-- Imagem do preview -->
        <meta property="og:image" content="/img/logotipo.ico">

        <!-- URL da página -->
        <meta property="og:url" content="https://iliac-markita-nattily.ngrok-free.dev">

        <!-- Tipo de conteúdo -->
        <meta property="og:type" content="website">

    </head>

    <body>
        <div class="container p-1">
            <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom border-3 border-primary">
                <div class="container-fluid">

                    <a class="navbar-brand" href="/"><b>CRTN Belém</b></a>

                    {{#if studentMassMessageBell}}
                    <a
                        class="student-message-bell-link ms-auto me-2 {{#unless studentMassMessageBell.hasUnread}}is-idle{{/unless}}"
                        id="studentMassMessageBellLink"
                        href="{{studentMassMessageBell.href}}"
                        aria-label="Mensagens do Mestre"
                        title="Mensagens do Mestre"
                    >
                        <span class="student-message-bell-icon" id="studentMassMessageBellIcon">
                            <i class="fa-solid fa-bell{{#if studentMassMessageBell.hasUnread}} fa-shake text-primary{{else}} text-secondary{{/if}}"></i>
                        </span>
                        <span class="badge rounded-pill text-bg-danger position-absolute top-0 start-50 translate-middle student-message-bell-badge {{#unless studentMassMessageBell.hasUnread}}d-none{{/unless}}" id="studentMassMessageBellBadge">{{studentMassMessageBell.unreadCount}}</span>
                    </a>
                    {{/if}}

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav w-100">

                            <!-- usuário logado -->
                            {{#if usuarioLogado}}
                            <li class="nav-item">
                                <span class="nav-link disabled">
                                    {{#if viewingAs}}
                                    <i class="fa-solid fa-child"></i> {{viewingAs.first_name}} {{viewingAs.last_name}}
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <a class="dropdown-item text-info" href="/conta/voltar">
                                    <i class="fa-solid fa-arrow-left"></i> Voltar para minha conta
                                </a>
                            </li>
                            {{else}}
                            <i class="fa-solid fa-user"></i>
                            {{usuarioLogado.first_name}} {{usuarioLogado.last_name}}
                            {{/if}}

                            </span>
                            </li>
                            {{/if}}

                            {{#if usuarioLogado}}
                            <li class="nav-item">
                                <span class="nav-link text-uppercase">
                                    <i class="fa-solid fa-square-binary"></i> Código: {{usuarioLogado.user_code}}
                                </span>
                            </li>
                            {{/if}}

                            <!-- Início conforme nível de acesso -->
                            <li class="nav-item">
                                <a class="nav-link" href="/dashboard">
                                    <i class="fa-solid fa-star"></i> INÍCIO
                                </a>
                            </li>

                            {{#if usuarioLogado}}
                            {{#if useProfessorMenu}}
                            {{> menuprofessor}}
                            {{else}}
                            {{> menualuno}}
                            {{/if}}
                            {{/if}}
                        </ul>
                    </div>
                </div>
            </nav>
        </div>

        <div class="container p-2">
            <div class="mt-3 mb-1">
                {{{body}}}
            </div>
        </div>

        {{#if birthdayLoginModal}}
        <div class="modal fade" id="birthdayLoginModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">{{birthdayLoginModal.title}}</h5>
                    </div>
                    <div class="modal-body text-center">
                        {{{birthdayLoginModal.bodyHtml}}}
                    </div>
                    <div class="modal-footer justify-content-start align-items-start flex-column flex-sm-row gap-2">
                        <div class="form-check m-0">
                            <input class="form-check-input" type="checkbox" value="1" id="birthdayDisableMessagesCheckbox">
                            <label class="form-check-label" for="birthdayDisableMessagesCheckbox">
                                {{birthdayLoginModal.checkboxLabel}}
                            </label>
                        </div>
                        <button type="button" class="btn btn-primary px-4" id="birthdayLoginModalCloseButton">Fechar</button>
                    </div>
                </div>
            </div>
        </div>
        {{/if}}

        <script src="/js/popper.min.js" defer></script>
        <script src="/js/bootstrap.min.js" defer></script>
        <script src="/js/auto-dismiss.js" defer></script>
        <script>
            function updateStudentMassMessageBell(unreadCount) {
                const bellLink = document.getElementById('studentMassMessageBellLink');
                const bellIcon = document.getElementById('studentMassMessageBellIcon');
                const bellBadge = document.getElementById('studentMassMessageBellBadge');
                const menuBadge = document.getElementById('studentMassMessageMenuBadge');

                if (!bellLink || !bellIcon || !bellBadge) {
                    return;
                }

                const normalizedUnreadCount = Math.max(Number(unreadCount) || 0, 0);
                const hasUnread = normalizedUnreadCount > 0;

                bellLink.classList.toggle('is-idle', !hasUnread);
                bellIcon.innerHTML = hasUnread
                    ? '<i class="fa-solid fa-bell fa-shake text-primary"></i>'
                    : '<i class="fa-solid fa-bell text-secondary"></i>';

                bellBadge.textContent = String(normalizedUnreadCount);
                bellBadge.classList.toggle('d-none', !hasUnread);

                if (menuBadge) {
                    menuBadge.textContent = String(normalizedUnreadCount);
                    menuBadge.classList.toggle('d-none', !hasUnread);
                }
            }
        </script>
        {{#if birthdayLoginModal}}
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const modalElement = document.getElementById('birthdayLoginModal');
                if (!modalElement || typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                    return;
                }

                const modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
                const closeButton = document.getElementById('birthdayLoginModalCloseButton');
                const checkbox = document.getElementById('birthdayDisableMessagesCheckbox');

                modalInstance.show();

                if (!closeButton) {
                    return;
                }

                closeButton.addEventListener('click', async function() {
                    closeButton.disabled = true;

                    try {
                        if (checkbox && checkbox.checked) {
                            await fetch('/aniversario/mensagens/desativar', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                body: JSON.stringify({ disable: true })
                            });
                        }
                    } catch (error) {
                        console.error('Erro ao salvar preferência de aniversário:', error);
                    } finally {
                        modalInstance.hide();
                        closeButton.disabled = false;
                    }
                });
            });
        </script>
        {{/if}}

    </body>

</html>