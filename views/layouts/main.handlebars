<!doctype html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="mobile-web-app-capable" content="yes">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
        <style>
            .table-mobile-stack {
                width: 100%;
            }

            .table-mobile-stack td {
                overflow-wrap: anywhere;
            }

            @media (max-width: 768px) {
                .table-mobile-stack thead {
                    display: none;
                }

                .table-mobile-stack,
                .table-mobile-stack tbody,
                .table-mobile-stack tr,
                .table-mobile-stack td {
                    display: block;
                    width: 100%;
                }

                .table-mobile-stack tbody tr {
                    margin-bottom: 1rem;
                    border: 1px solid var(--bs-border-color);
                    border-radius: 0.75rem;
                    background-color: var(--bs-body-bg);
                    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
                    overflow: hidden;
                }

                .table-mobile-stack tbody td {
                    display: flex;
                    justify-content: space-between;
                    gap: 1rem;
                    padding: 0.75rem 1rem;
                    border: 0;
                    border-bottom: 1px solid var(--bs-border-color-translucent);
                    text-align: right;
                }

                .table-mobile-stack tbody td:last-child {
                    border-bottom: 0;
                }

                .table-mobile-stack tbody td::before {
                    content: attr(data-label);
                    font-weight: 600;
                    color: var(--bs-secondary-color);
                    text-align: left;
                    margin-right: 1rem;
                }
            }
        </style>
        <title>Sistema Oss - Gestão de Jiu-jitsu</title>
    </head>

    <body>
        <div class="container mt-2 p-1">
            <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom border-3 border-primary">
                <div class="container-fluid">

                    <a class="navbar-brand" href="/">CRTN Belém</a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav w-100">

                            {{#if usuarioLogado}}
                            <li class="nav-item">
                                <span class="nav-link disabled">
                                    <i class="fa-solid fa-user"></i> {{usuarioLogado.first_name}} ({{usuarioLogado.role}})
                                </span>
                            </li>
                            {{/if}}

                            <!-- Dashboard: ambos perfis terão acesso -->
                            <li class="nav-item">
                                <a class="nav-link" href="/dashboard">
                                    <i class="fa-solid fa-layer-group"></i> CENTRAL
                                </a>
                            </li>


                            <!-- Portal: verificar o nível do acesso e prover as opções do menu -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-graduation-cap"></i> PORTAL DO ALUNO
                                </a>

                                <ul class="dropdown-menu">
                                    <li class="dropdown-header text-muted">Para você</li>
                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa-solid fa-clipboard-user"></i> Meu Perfil
                                        </a>
                                    </li>
                                    
                                    <!-- Área de controle -->
                                    <li><hr class="dropdown-divider"></li>
                                    <li class="dropdown-header text-muted">Você no controle</li>
                                    <li><a class="dropdown-item" href="#"><i class="fa-solid fa-calendar-check"></i>
                                            Controle de Presença</a></li>
                                    <li><a class="dropdown-item" href="#"><i class="fa-solid fa-chart-line"></i> Meu
                                            Progresso</a></li>
                                    <li><a class="dropdown-item" href="#"><i class="fa-solid fa-chart-pie"></i>
                                            Relatórios</a></li>
                                    
                                    
                                    {{#if true }}
                                    <!-- habilitar este menu caso ele seja titular de outras contas -->
                                    <li><hr class="dropdown-divider"></li>
                                    <li class="dropdown-header text-muted">Gerenciar contas</li>
                                    <li><a class="dropdown-item" href="#"><i class="fa-solid fa-child"></i> Conta: dependente 1</a></li>
                                    <li><a class="dropdown-item" href="#"><i class="fa-solid fa-child"></i> Conta: dependente 2</a></li>
                                    <li><a class="dropdown-item" href="#"><i class="fa-solid fa-child"></i> Conta: dependente 3</a></li>
                                    {{/if}}


                                    <!-- Sair do sistema -->
                                    <li><hr class="dropdown-divider"></li>
                                    <li class="dropdown-header text-muted">Sair do sistema</li>
                                    <li>
                                        <form action="/auth/logout" method="POST" class="px-3 py-1">
                                            <button type="submit" class="dropdown-item text-danger p-0 border-0 bg-transparent text-start">
                                                <i class="fa-solid fa-person-walking-arrow-right"></i> Encerrar
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </div>

        <div class="container p-2">
            <div class="mt-5 mb-3">
                {{{body}}}
            </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js"></script>
        <script src="/js/auto-dismiss.js"></script>
    </body>

</html>